# Copy this file to .env and fill in your values.
# Get these from your Supabase project → Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only needed for the seed script, NEVER expose in frontend
# Found in Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# User ID to seed data under — find in Supabase Dashboard → Authentication → Users
SEED_USER_ID=your-user-uuid-here

# Optional — defaults to http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Optional — defaults to 3001
PORT=3001
